---
// DrillIcon.astro - Animated drill icon for header navigation
// Original 32x32 viewBox preserved; overflow="visible" for rock/spark effects
---
<svg width="24" height="24" viewBox="0 0 32 32" overflow="visible" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
  <!-- Environment: rock, sparks, debris -->
  <g class="environment">
    <!-- Rock slides in from the left on hover -->
    <g class="rock-mover">
      <g class="rock-vibrate">
        <path d="M -1.5 13 L 2.5 14 L 5 18.5 L 3 23 L -1.5 25 L -5.5 22 L -4.5 16 Z" stroke-width="1.5" />
        <path d="M -0.5 17 L 2 19 L 5 18.5" stroke-width="1.5" opacity="0.6" />
      </g>
    </g>
    <!-- Sparks at contact point -->
    <g class="sparks" stroke-width="1.5">
      <line class="spark spark-1" x1="6.8" y1="16.8" x2="10.3" y2="13.3" />
      <line class="spark spark-2" x1="7.1" y1="17.8" x2="11.9" y2="19.1" />
      <line class="spark spark-3" x1="6.6" y1="18.4" x2="9.1" y2="22.7" />
    </g>
    <!-- Debris particles -->
    <g class="debris-group" fill="currentColor" stroke="none">
      <circle class="debris d1" cx="6.0" cy="17.6" r="0.8" />
      <circle class="debris d2" cx="6.0" cy="17.6" r="1.2" />
      <circle class="debris d3" cx="6.0" cy="17.6" r="0.7" />
    </g>
  </g>

  <!-- Drill body (rotated -30deg via CSS .drill-wrapper) -->
  <g class="drill-wrapper">
    <g class="drill-vibrate">
      <!-- Bit -->
      <line class="bit" x1="6" y1="12" x2="11" y2="12" />
      <!-- Chuck -->
      <polygon points="14,9.5 11,10.5 11,13.5 14,14.5" />
      <!-- Body -->
      <rect x="14" y="9" width="10" height="6" rx="1.5" />
      <!-- Motor vents -->
      <line x1="20.5" y1="10" x2="20.5" y2="14" stroke-width="1.5" opacity="0.6" />
      <line x1="22" y1="10" x2="22" y2="14" stroke-width="1.5" opacity="0.6" />
      <!-- Handle -->
      <path d="M 18 15 L 19 22" />
      <path d="M 22 15 L 23 22" />
      <!-- Battery -->
      <rect x="17" y="22" width="8" height="4" rx="1" />
      <!-- Trigger -->
      <line class="trigger" x1="18" y1="17" x2="16" y2="17" />
    </g>
  </g>
</svg>
